# Public canonical site URL (no trailing slash). Used for sitemap, OG tags, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://codemaddy-site.netlify.app

# Optional. Full Medium profile URL — feeds JSON-LD sameAs only.
NEXT_PUBLIC_MEDIUM_URL=https://medium.com/@madandoor7s

# Optional. Google Search Console verification token (meta-tag method).
NEXT_PUBLIC_GOOGLE_VERIFICATION=

# Optional. Plausible analytics domain (e.g. codemaddy-site.netlify.app). When set,
# the Plausible script is injected in <head>. Leave blank to disable analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Optional. Formspree form ID — sign up free at https://formspree.io and paste the ID here.
# When set, the contact form posts to Formspree. When unset, it falls back to mailto:.
NEXT_PUBLIC_FORMSPREE_ID=
