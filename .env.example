# Public canonical site URL (no trailing slash). Used for sitemap, OG tags, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://maddy-portfolio-site.netlify.app

# Optional. Username only (without @). Enables the Writing section pulled from Medium RSS.
# Example: madandoor7s
MEDIUM_USERNAME=

# Optional. Full Medium profile URL shown in footer/contact (defaults to a sensible value).
NEXT_PUBLIC_MEDIUM_URL=https://medium.com/@madandoor7s

# Optional. Formspree form ID — sign up free at https://formspree.io and paste the ID here.
# When set, the contact form posts to Formspree. When unset, it falls back to mailto:.
NEXT_PUBLIC_FORMSPREE_ID=
